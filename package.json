{
  "name": "@finografic/lucide-manager",
  "type": "module",
  "version": "0.1.1",
  "private": false,
  "packageManager": "pnpm@10.8.0",
  "description": "Browse, select, and manage Lucide icons for your design system registry.",
  "homepage": "https://github.com/finografic/lucide-manager",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/finografic/lucide-manager.git"
  },
  "bugs": {
    "url": "https://github.com/finografic/lucide-manager/issues"
  },
  "author": {
    "name": "Justin Rankin",
    "email": "justin.blair.rankin@gmail.com",
    "url": "https://github.com/finografic"
  },
  "license": "MIT",
  "keywords": [
    "finografic",
    "lucide-manager",
    "genx:type:cli",
    "lucide",
    "icon-picker",
    "design-system"
  ],
  "bin": {
    "lucide-manager": "./bin/lucide-manager.js"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "scripts": {
    "========== DEV": "=======================================================",
    "dev": "vite",
    "·········· BUILD": "·····················································",
    "build": "vite build",
    "generate": "tsx scripts/generate-icons-ts.ts",
    "·········· TESTING": "···················································",
    "test": "vitest",
    "test.run": "vitest run",
    "test.coverage": "vitest run --coverage",
    "·········· LINTING": "···················································",
    "lint": "eslint .",
    "lint.fix": "eslint . --fix",
    "·········· FORMATTING": "··················································",
    "format": "dprint fmt --diff",
    "format.check": "dprint check",
    "·········· UTILS": "·····················································",
    "tsc.debug": "tsc --pretty --project tsconfig.json",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "·········· HOOKS": "·····················································",
    "prepare": "simple-git-hooks",
    "·········· PACKAGES": "··················································",
    "update.eslint-config": "pnpm update @finografic/eslint-config --latest",
    "upgrade.deps.all": "pnpm update --latest",
    "update.dprint-config": "pnpm update @finografic/dprint-config --latest",
    "·········· PUBLISH.GITHUB": "············································",
    "release.github.patch": "pnpm run release.check && pnpm version patch && git push --follow-tags",
    "release.github.minor": "pnpm run release.check && pnpm version minor && git push --follow-tags",
    "release.github.major": "pnpm run release.check && pnpm version major && git push --follow-tags",
    "release.check": "pnpm format.check && pnpm lint.fix && pnpm typecheck && pnpm test.run",
    "release.publish": "pnpm publish --registry https://npm.pkg.github.com",
    "·········· REGISTRIES": "··············································",
    "view.registry.github": "pnpm view @finografic/lucide-manager --registry=https://npm.pkg.github.com"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.2.0",
    "@commitlint/config-conventional": "^20.2.0",
    "@eslint/js": "^9.39.2",
    "@finografic/dprint-config": "^0.12.4",
    "@stylistic/eslint-plugin": "^5.6.1",
    "@types/node": "^24.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^8.51.0",
    "@typescript-eslint/parser": "^8.51.0",
    "@vitejs/plugin-react": "^4.3.4",
    "dprint": "^0.51.1",
    "eslint": "9.39.2",
    "eslint-plugin-markdownlint": "^0.9.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^17.3.0",
    "lint-staged": "^16.2.7",
    "simple-git-hooks": "^2.13.1",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.51.0",
    "vite": "^6.3.5",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "dprint fmt --allow-no-files",
      "eslint --fix"
    ],
    "*.{json,jsonc,md,yml,yaml,toml}": [
      "dprint fmt --allow-no-files"
    ]
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged --allow-empty"
  }
}
